{
  "name": "lexreclama-web",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build:css": "lightningcss --minify --targets '>= 0.25%' styles.css -o styles.min.css",
    "build:js": "esbuild app.js --bundle=false --minify --outfile=app.min.js",
    "build": "npm run build:css && npm run build:js",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run build && git add styles.min.css app.min.js"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "lightningcss-cli": "^1.30.2",
    "simple-git-hooks": "^2.11.1"
  },
  "dependencies": {
    "busboy": "^1.6.0"
  }
}
