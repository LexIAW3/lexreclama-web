{
  "name": "lexreclama-web",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build:css": "lightningcss --minify --targets '>= 0.25%' styles.css -o styles.min.css",
    "build:js": "esbuild app.js --bundle=false --minify --outfile=app.min.js",
    "build": "npm run build:css && npm run build:js"
  },
  "devDependencies": {
    "esbuild": "^0.27.3",
    "lightningcss-cli": "^1.30.2"
  }
}
